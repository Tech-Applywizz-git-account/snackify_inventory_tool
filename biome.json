{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"backend/src/**",
			"frontend/src/**/*.{js,jsx}",
			"!**/node_modules/**",
			"!**/dist/**",
			"!**/build/**",
			"!backend/src/server.js.backup",
			"!my-agent/**"
		]
	},
	"css": {
		"linter": {
			"enabled": false
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noConsole": "off",
				"noArrayIndexKey": "warn",
				"noUnknownAtRules": "warn"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"a11y": {
				"noLabelWithoutControl": "warn",
				"useButtonType": "warn",
				"noSvgWithoutTitle": "warn",
				"useKeyWithClickEvents": "warn",
				"noStaticElementInteractions": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "es5",
			"semicolons": "always",
			"arrowParentheses": "always"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
