# Supabase (same project as main app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Rocket thermal printer on office LAN (Wi-Fi/Ethernet)
# Find IP: print a self-test page from printer, or check router DHCP list
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Windows USB only (leave PRINTER_IP blank or use spooler name instead)
# PRINTER_NAME=58mm Series Printer
