# Supabase connection (same project as the main app)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE KEY (not anon key) so the print agent can write
# back to meal_print_jobs and meal_bookings (update print_count, status etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_service_role_key...

# Thermal printer (OCPP-88A) on LAN
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
