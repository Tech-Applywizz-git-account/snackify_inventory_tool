PORT=4000
NODE_ENV=development

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_service_role_key...
SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key...

ALLOWED_ORIGINS=http://localhost:5173,https://snackify.applywizz.ai

# Where the app is reachable from a browser. Used for auth/invite redirects and Teams cards.
# Production example:
# APP_PUBLIC_URL=https://snackify.applywizz.ai
APP_PUBLIC_URL=http://localhost:5173

# Optional: weekly AI summary and request parsing.
OPENAI_API_KEY=

# Optional: Microsoft Teams Incoming Webhook URL. When a request is created,
# we post an Adaptive Card to this URL so the Office Boy sees it in Teams.
# How to get one: in Teams -> the channel where Office Boy lives ->
#   ... menu -> Connectors -> Incoming Webhook -> Configure -> name "Applywizz Pantry" -> Create.
# Paste the URL Teams gives you below. Leave blank to disable.
TEAMS_WEBHOOK_URL=

# Power Automate bill upload webhook secret.
# Power Automate should POST to:
#   https://your-api-host/api/bills/webhook?key=<this value>
BILL_WEBHOOK_KEY=app_wizz_secure_782

# Telegram bill upload bot.
# Set Telegram webhook to:
#   https://your-api-host/api/telegram/webhook?key=<TELEGRAM_WEBHOOK_KEY>
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_KEY=app_wizz_telegram_secret

# AI Cron endpoint secret (used by pg_cron to authenticate)
CRON_SECRET=app_wizz_cron_secret_change_in_production

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@applywizz.ai

# Power Automate / Teams webhook (outbound)
POWER_AUTOMATE_URL=

# Microsoft Graph (Entra directory) — validates that a login email belongs to a
# real, enabled user in the Azure directory before any account is created.
# Get these from Azure Portal -> Entra ID -> App registrations -> your app.
# The CLIENT_SECRET is sensitive: keep it only in .env, never commit it.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Temporary password set on Supabase accounts created via POST /api/admin/users/create.
# Users change it on first TOTP enrollment — it is never surfaced in logs or API responses.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64url') + '@Tmp')"
# Required in production. If unset, /users/create returns 503.
DEFAULT_PASSWORD=

# HMAC secret for OTP and enrollment-token hashing.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the real value. Keep backend-only.
OTP_HASH_SECRET=
